


import os
import json
from pathlib import Path
from IPython.display import display, Image
from dotenv import load_dotenv

# OpenAI & ChromaDB - Embedding + Vector Store
import openai
import chromadb

# LandingAI ADE - New Library
from landingai_ade import LandingAIADE
from landingai_ade.types import ParseResponse

# Load environment variables from .env
load_dotenv(override=True)

# Initialize the ADE client
client = LandingAIADE()

# Load OpenAI's API Key
openai.api_key = os.getenv("OPENAI_API_KEY")

print("✅ LandingAI ADE client initialized")
print("✅ OpenAI API configured")








# Setting Directories and Paths
DOC_PATH = Path("apple_10k.pdf")
OUTPUT_DIR = Path("./ade_outputs")
ADE_JSON_PATH = OUTPUT_DIR / "apple_10k.json"
ADE_MD_PATH = OUTPUT_DIR / "apple_10k.md"

# Create output directory if it doesn't exist
OUTPUT_DIR.mkdir(exist_ok=True)

print(f"📁 Document: {DOC_PATH}")
print(f"📁 Output directory: {OUTPUT_DIR}")








def normalize_chunk(chunk_dict):
    """
    Convert a chunk dictionary to a normalized format for storage.
    Handles nested dictionaries and lists.
    """
    normalized = {}
    for k, v in chunk_dict.items():
        if isinstance(v, Path):
            normalized[k] = str(v)
        elif isinstance(v, list):
            normalized[k] = [
                normalize_chunk(i) if isinstance(i, dict) else (str(i) if isinstance(i, Path) else i)
                for i in v
            ]
        elif isinstance(v, dict):
            normalized[k] = normalize_chunk(v)
        else:
            normalized[k] = v
    return normalized








print(f"🚀 Starting document parsing: {DOC_PATH.name}")

# Step 1: Parse the document using the new landingai_ade library
parse_result: ParseResponse = client.parse(
    document=DOC_PATH,
    split="page",
    model="dpt-2-latest"
)

print(f"✅ Parsing completed - {len(parse_result.splits)} pages processed")

# Step 2: Combine all splits into full markdown and collect chunks
all_markdown = []
all_chunks = []

for i, split in enumerate(parse_result.splits):
    all_markdown.append(split.markdown)
    
    # Extract chunks from each split
    for chunk in split.chunks:
        chunk_dict = {
            "chunk_id": f"page_{i}_{chunk.chunk_type}_{len(all_chunks)}",
            "chunk_type": chunk.chunk_type,
            "text": chunk.text,
            "page": i,
            "bbox": chunk.bbox if hasattr(chunk, 'bbox') else None
        }
        all_chunks.append(chunk_dict)

# Combine markdown from all pages
full_markdown = "\n\n".join(all_markdown)

# Step 3: Save outputs
print("💾 Saving outputs...")

# Save Markdown
with open(ADE_MD_PATH, "w", encoding="utf-8") as f:
    f.write(full_markdown)
print(f"   ✓ Markdown saved: {ADE_MD_PATH}")

# Normalize and save chunks as JSON
normalized_chunks = [normalize_chunk(c) for c in all_chunks]
with open(ADE_JSON_PATH, "w", encoding="utf-8") as f:
    json.dump(normalized_chunks, f, indent=2)
print(f"   ✓ JSON saved: {ADE_JSON_PATH}")

print(f"\n📊 Summary:")
print(f"   - Pages processed: {len(parse_result.splits)}")
print(f"   - Total chunks: {len(all_chunks)}")
print(f"   - Markdown length: {len(full_markdown)} characters")
print(f"\n✅ Parsing complete!")








# Instantiate the Chroma Client
chroma_client = chromadb.PersistentClient(path="./chroma_db")

# Create or Load ADE Collection
collection = chroma_client.get_or_create_collection(name="ade_documents")








print(f"📤 Inserting {len(normalized_chunks)} chunks into Chroma...")

for i, chunk in enumerate(normalized_chunks):
    text = chunk.get("text", "")
    chunk_id = chunk["chunk_id"]
    
    # Skip empty chunks
    if not text or not text.strip():
        continue
    
    # Flatten Metadata (Simple Types Only)
    metadata = {
        "chunk_type": chunk.get("chunk_type", "unknown"),
        "page": chunk.get("page")
    }
    
    # Add bbox if available
    if chunk.get("bbox"):
        metadata["has_bbox"] = True

    # Generate Embeddings with OpenAI
    emb = openai.embeddings.create(
        input=text,
        model="text-embedding-3-small"
    ).data[0].embedding

    # Store in Chroma
    collection.add(
        documents=[text],
        ids=[chunk_id],
        metadatas=[metadata],
        embeddings=[emb]
    )
    
    # Progress indicator
    if (i + 1) % 20 == 0:
        print(f"   Processed {i + 1}/{len(normalized_chunks)} chunks...")

print(f"\n✅ Successfully inserted {len(normalized_chunks)} chunks into Chroma!")








def rag_query(question, top_k=3, threshold=0.25):
    """
    Query the ADE Chroma index with a natural language question.
    
    Args:
        question (str): User query
        top_k (int): Max results to return
        threshold (float): Minimum similarity (1 - distance)
    """
    # 1. Embed Query
    q_embed = openai.embeddings.create(
        model="text-embedding-3-small",
        input=question
    ).data[0].embedding

    # 2. Query Chroma
    results = collection.query(
        query_embeddings=[q_embed],
        n_results=top_k,
        include=["documents", "metadatas", "distances"]
    )

    print(f"\n🔎 Query: {question}\n")

    # 3. Parse Results
    retrieved_docs = results["documents"][0]
    retrieved_meta = results["metadatas"][0]
    retrieved_dists = results["distances"][0]
    retrieved_ids = results["ids"][0]

    found_any = False
    for i, (doc, meta, dist, cid) in enumerate(zip(
        retrieved_docs, retrieved_meta, retrieved_dists, retrieved_ids
    )):
        similarity = 1 - dist
        if similarity < threshold:
            continue  # Skip Weak Matches

        found_any = True
        print(f"📄 Result {i+1} (similarity={similarity:.3f}):")
        print(f"   Chunk ID: {cid}")
        print(f"   Type: {meta.get('chunk_type')}, Page: {meta.get('page')}")
        print(f"   Text: {doc[:200]}...")
        print("-" * 80)

    if not found_any:
        print("❌ No results above similarity threshold.")
    
    return results








# Pass in Question in Natural Language, Top_K, and Threhold/Cosine Distance
rag_query("What was Apple’s net sales in 2023?", top_k=5, threshold=0.32)



